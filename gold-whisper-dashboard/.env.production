# Production Environment Variables for Vercel Deployment

# Supabase Configuration (set in hosting secrets or fill placeholders)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Chatwoot Configuration (ACTUALIZAR ESTAS URLs DESPUÉS DEL DEPLOYMENT)
# IMPORTANTE: Reemplaza estas URLs con las URLs reales de Railway después de desplegar
VITE_CHATWOOT_URL=
VITE_CHATWOOT_ACCOUNT_ID=
VITE_CHATWOOT_USER_TOKEN=
VITE_CHATWOOT_WEBSITE_TOKEN=
VITE_CHATWOOT_ENABLED=false

# Meta Ads Configuration
VITE_META_BUSINESS_ID=
VITE_META_ACCESS_TOKEN=

# Meta Ad Accounts (múltiples cuentas)
VITE_META_AD_ACCOUNT_IDS=
VITE_META_AD_ACCOUNT_NAMES=

# Cuenta principal (para compatibilidad)
VITE_META_AD_ACCOUNT_ID=
VITE_META_AD_ACCOUNT_NAME=

# Fallback Auth (permite ingresar cuando Supabase no esté accesible)
VITE_FALLBACK_AUTH_EMAIL=
VITE_FALLBACK_AUTH_PASSWORD=
VITE_FALLBACK_AUTH_NAME=
VITE_ENABLE_FALLBACK_AUTH=false
VITE_FALLBACK_ALLOWED_EMAILS=
VITE_BRIDGE_API_URL=

# AOV (ticket promedio) para estimar ingresos por categoría
VITE_DEFAULT_AOV=285000
VITE_AOV_BALINERIA=285000
VITE_AOV_JOYERIA=285000

# Claude AI Configuration (Anthropic)
# Get your API key from: https://console.anthropic.com/settings/keys
VITE_CLAUDE_API_KEY=
VITE_CLAUDE_MODEL=claude-3-5-sonnet-20241022
VITE_CLAUDE_ENABLED=false
