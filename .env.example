# Copy this file to `.env` (for local) or use it to configure env vars in your hosting.
# Never commit real secrets. Only keep this template in git.

# =========================
# Supabase
# =========================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional publishable key alias (if used):
VITE_SUPABASE_PUBLISHABLE_KEY=

# =========================
# Chatwoot / Bridge API
# =========================
VITE_CHATWOOT_ENABLED=false
VITE_CHATWOOT_URL=
VITE_CHATWOOT_WEBSITE_TOKEN=
VITE_CHATWOOT_ACCOUNT_ID=
VITE_CHATWOOT_USER_TOKEN=
# Bridge proxy that the app calls instead of Chatwoot directly
VITE_BRIDGE_API_URL=

# =========================
# Meta Ads (Facebook Graph API)
# =========================
VITE_META_ACCESS_TOKEN=
VITE_META_ACCESS_TOKEN_2=
# Single main account (compatibility)
VITE_META_AD_ACCOUNT_ID=
VITE_META_AD_ACCOUNT_NAME=
# Comma-separated for multiple accounts
VITE_META_AD_ACCOUNT_IDS=
VITE_META_AD_ACCOUNT_NAMES=
# Optional business id
VITE_META_BUSINESS_ID=

# =========================
# CRM/Estimations
# =========================
VITE_DEFAULT_AOV=285000
VITE_AOV_BALINERIA=285000
VITE_AOV_JOYERIA=285000

# =========================
# Fallback auth (desarrollo/demo u OFFLINE)
// Si true, permite iniciar sesión sin Supabase (útil en demo/Pages). La contraseña se ignora.
VITE_ENABLE_FALLBACK_AUTH=false
// Email que podrá acceder en modo invitado; si se omite, cualquier email funciona.
VITE_FALLBACK_AUTH_EMAIL=
// Nombre a mostrar para el usuario invitado.
VITE_FALLBACK_AUTH_NAME=
// Lista de emails permitidos (coma separada). Tiene prioridad sobre VITE_FALLBACK_AUTH_EMAIL.
VITE_FALLBACK_ALLOWED_EMAILS=

# =========================
# Optional AI providers
# =========================
VITE_GEMINI_API_KEY=
VITE_CLAUDE_API_KEY=
VITE_CLAUDE_MODEL=claude-3-5-sonnet-20241022

# =========================
# Router base (optional)
# =========================
VITE_ROUTER_BASENAME=/
# ===== NEXT & APP =====
NEXT_PUBLIC_APP_NAME=GALLE
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===== META / FACEBOOK ADS (Servidor) =====
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v19.0
META_BUSINESS_ID=
META_AD_ACCOUNT_ID=act_XXXXXXXXXXXXXXX
META_LONG_LIVED_TOKEN=

# ===== SUPABASE (si aplica) =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== VERCEL BLOB (si se usa) =====
BLOB_READ_WRITE_TOKEN=

# ===== AUTH (si se usa) =====
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ===== OTRAS INTEGRACIONES =====
MIPAQUETE_API_KEY=
